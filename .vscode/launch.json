{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI (Backend)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "DEBUG": "true"
            },
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "d:\\anaconda3\\envs\\dev_env\\python.exe"
        },
        {
            "name": "Pytest: test_TC01_captcha_returns_id_and_base64_image",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_auth.py::test_TC01_captcha_returns_id_and_base64_image",
                "-v",
                "-s"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "DEBUG": "true",
                "TESTING": "true"
            },
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "d:\\anaconda3\\envs\\dev_env\\python.exe"
        },
        {
            "name": "Python: Pytest Current File",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "-s",
                "--no-header"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "DEBUG": "true",
                "TESTING": "true"
            },
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "d:\\anaconda3\\envs\\dev_env\\python.exe"
        }
    ]
}
